APP_IMAGE=ghcr.io/panbartosz/zuzia-i-adam:latest

# For a domain with automatic HTTPS, use:
# CADDY_SITE_ADDRESS=zdjecia.example.com
# APP_BASE_URL=https://zdjecia.example.com
#
# For a quick HTTP test on port 80:
CADDY_SITE_ADDRESS=:80
APP_BASE_URL=http://localhost
HTTP_PORT=80
HTTPS_PORT=443

POSTGRES_DB=wedding
POSTGRES_USER=wedding
POSTGRES_PASSWORD=change-this-database-password

AUTH_SECRET=change-this-to-a-long-random-secret
ADMIN_EMAIL=admin@zuziaiadam.pl
ADMIN_PASSWORD=change-this-admin-password

COUPLE_NAME=Zuzia & Adam
WEDDING_DATE=
UPLOAD_TOKEN=change-this-upload-token
GALLERY_TOKEN=change-this-gallery-token
